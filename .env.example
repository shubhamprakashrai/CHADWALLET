# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# All services have a free tier. See _context/CONTEXT.md section 8.

# --- Privy (auth + embedded Solana wallet) ---
EXPO_PUBLIC_PRIVY_APP_ID=
EXPO_PUBLIC_PRIVY_CLIENT_ID=

# --- Birdeye (token market data) ---
EXPO_PUBLIC_BIRDEYE_API_KEY=

# --- Codex.io (token market data) ---
EXPO_PUBLIC_CODEX_API_KEY=

# --- Alchemy (Solana RPC) ---
EXPO_PUBLIC_ALCHEMY_RPC_MAINNET=
EXPO_PUBLIC_ALCHEMY_RPC_DEVNET=

# --- Supabase (backend / cache) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Network toggle: "devnet" while testing, "mainnet" when ready ---
EXPO_PUBLIC_SOLANA_NETWORK=devnet
